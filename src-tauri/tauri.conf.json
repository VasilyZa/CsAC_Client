{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CsAC Client",
  "version": "0.1.2",
  "identifier": "com.csac.client.app",
  "build": {
    "beforeDevCommand": "env NO_COLOR=false trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "env NO_COLOR=false trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CsAC 桌面客户端",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
